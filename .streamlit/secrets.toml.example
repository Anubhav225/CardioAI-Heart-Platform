# ──────────────────────────────────────────────────────────────
# .streamlit/secrets.toml.example
#
# This is a TEMPLATE. Copy this file to ".streamlit/secrets.toml"
# (same folder) and fill in your real key there.
#
# secrets.toml is listed in .gitignore and will NEVER be committed
# or pushed to GitHub. The app reads this key only on the server
# side via st.secrets — it is never displayed, logged, or returned
# to the browser in any form.
#
# Get a free Groq API key at: https://console.groq.com/keys
# ──────────────────────────────────────────────────────────────

GROQ_API_KEY = "your_groq_api_key_here"
